<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background: radial-gradient(circle at top left, #e0f2fe 0, #f5f8ff 35%, #eef4ff 100%);
      color: #172033;
      padding: 28px 16px 42px;
    }

    .page {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      gap: 18px;
    }

    .card {
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid #d8e4f3;
      border-radius: 22px;
      box-shadow: 0 16px 40px rgba(22, 34, 51, 0.08);
      padding: 22px;
    }

    .hero {
      display: grid;
      grid-template-columns: 1fr auto auto;
      align-items: center;
      gap: 18px;
    }

    .nav {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .nav a,
    .logout button {
      border: 0;
      border-radius: 999px;
      padding: 10px 14px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
    }

    .nav a {
      background: #174ea6;
      color: #ffffff;
    }

    .logout button {
      background: #dbeafe;
      color: #174ea6;
    }

    .summary-grid,
    .chart-grid {
      display: grid;
      gap: 18px;
    }

    .summary-grid {
      grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    }

    .chart-grid {
      grid-template-columns: repeat(auto-fit, minmax(420px, 1fr));
    }

    .summary-card {
      background: #0f172a;
      color: #e0f2fe;
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.18);
    }

    .summary-card strong {
      display: block;
      color: #ffffff;
      font-size: 2rem;
      margin-top: 8px;
    }

    .chart-card {
      min-height: 410px;
      display: grid;
      grid-template-rows: auto auto 1fr;
      gap: 8px;
    }

    .chart-card h2 {
      margin: 0;
      font-size: 1.16rem;
    }

    .chart-card p {
      margin: 0;
    }

    .chart-wrap {
      position: relative;
      height: 320px;
      width: 100%;
    }

    .muted {
      color: #64748b;
    }

    @media (max-width: 820px) {
      .hero {
        grid-template-columns: 1fr;
      }

      .chart-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="page">
    <section class="card hero">
      <div>
        <p class="muted">CW2 staff view</p>
        <h1><%= title %></h1>
        <p>Interactive graphs with legends, tooltips, axis labels, and multiple chart types for staff analysis.</p>
      </div>
      <nav class="nav">
        <a href="/staff/dashboard">Dashboard</a>
        <a href="/staff/records">View Records</a>
        <a href="/developer-portal">API Keys</a>
      </nav>
      <form class="logout" method="POST" action="/logout">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
        <button type="submit">Logout</button>
      </form>
    </section>

    <section class="summary-grid">
      <article class="summary-card">
        <span>Registered Records</span>
        <strong><%= summary.registeredAlumni %></strong>
      </article>
      <article class="summary-card">
        <span>Completed Profiles</span>
        <strong><%= summary.completedProfiles %></strong>
      </article>
      <article class="summary-card">
        <span>Feature Winners</span>
        <strong><%= summary.featuredWinners %></strong>
      </article>
      <article class="summary-card">
        <span>API Requests</span>
        <strong><%= summary.totalApiRequests %></strong>
      </article>
    </section>

    <section class="chart-grid">
      <article class="card chart-card">
        <h2>Records By Programme</h2>
        <p class="muted">Bar chart with labelled axes and hover values.</p>
        <div class="chart-wrap"><canvas id="programmeChart"></canvas></div>
      </article>

      <article class="card chart-card">
        <h2>Graduation Year Trend</h2>
        <p class="muted">Line chart showing profile counts across years.</p>
        <div class="chart-wrap"><canvas id="graduationChart"></canvas></div>
      </article>

      <article class="card chart-card">
        <h2>Industry Sector Split</h2>
        <p class="muted">Pie chart for sector distribution.</p>
        <div class="chart-wrap"><canvas id="industryChart"></canvas></div>
      </article>

      <article class="card chart-card">
        <h2>Blind Bidding Status</h2>
        <p class="muted">Doughnut chart for pending, won, lost, and cancelled bid states.</p>
        <div class="chart-wrap"><canvas id="bidChart"></canvas></div>
      </article>

      <article class="card chart-card">
        <h2>API Endpoint Usage</h2>
        <p class="muted">Horizontal bar chart for most accessed endpoints.</p>
        <div class="chart-wrap"><canvas id="endpointChart"></canvas></div>
      </article>

      <article class="card chart-card">
        <h2>API Daily Usage Trend</h2>
        <p class="muted">Line chart showing request volume over recent days.</p>
        <div class="chart-wrap"><canvas id="apiDailyChart"></canvas></div>
      </article>

      <article class="card chart-card">
        <h2>Profile Completeness</h2>
        <p class="muted">Radar chart showing completion percentage by profile section.</p>
        <div class="chart-wrap"><canvas id="completenessChart"></canvas></div>
      </article>

      <article class="card chart-card">
        <h2>Token And Request Health</h2>
        <p class="muted">Polar area chart for API outcomes plus token-status comparison.</p>
        <div class="chart-wrap"><canvas id="apiHealthChart"></canvas></div>
      </article>
    </section>
  </div>

  <script src="/vendor/chartjs/chart.umd.js"></script>
  <script>
    const graphData = <%- JSON.stringify(graphData).replace(/</g, "\\u003c") %>;
    const palette = [
      "#174ea6",
      "#0f766e",
      "#7c3aed",
      "#dc2626",
      "#ea580c",
      "#0891b2",
      "#65a30d",
      "#be185d",
      "#475569",
      "#ca8a04",
    ];

    function normalizeRows(rows, fallbackLabel = "No data") {
      if (!rows || rows.length === 0) {
        return [{ label: fallbackLabel, value: 0 }];
      }

      return rows;
    }

    function labels(rows) {
      return normalizeRows(rows).map((row) => row.label);
    }

    function values(rows) {
      return normalizeRows(rows).map((row) => row.value);
    }

    function chartColors(rows, opacity = 0.88) {
      return normalizeRows(rows).map((row, index) => {
        const color = palette[index % palette.length];
        return color.length === 7
          ? `${color}${Math.round(opacity * 255).toString(16).padStart(2, "0")}`
          : color;
      });
    }

    function sharedOptions({ title, xTitle, yTitle, legend = true, beginAtZero = true } = {}) {
      return {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            display: legend,
            position: "bottom",
            labels: {
              boxWidth: 14,
              usePointStyle: true,
            },
          },
          tooltip: {
            enabled: true,
            callbacks: {
              label(context) {
                const label = context.dataset.label || context.label || "Value";
                const value = context.parsed?.y ?? context.parsed?.x ?? context.parsed ?? 0;
                return `${label}: ${value}`;
              },
            },
          },
          title: {
            display: Boolean(title),
            text: title,
          },
        },
        scales: {
          x: {
            beginAtZero,
            title: {
              display: Boolean(xTitle),
              text: xTitle,
            },
            ticks: {
              autoSkip: false,
              maxRotation: 35,
              minRotation: 0,
            },
          },
          y: {
            beginAtZero,
            title: {
              display: Boolean(yTitle),
              text: yTitle,
            },
            ticks: {
              precision: 0,
            },
          },
        },
      };
    }

    function createBarChart(canvasId, rows, datasetLabel, axisLabels = {}) {
      return new Chart(document.getElementById(canvasId), {
        type: "bar",
        data: {
          labels: labels(rows),
          datasets: [
            {
              label: datasetLabel,
              data: values(rows),
              backgroundColor: chartColors(rows),
              borderColor: palette[0],
              borderWidth: 1,
              borderRadius: 8,
            },
          ],
        },
        options: sharedOptions({
          title: datasetLabel,
          xTitle: axisLabels.x,
          yTitle: axisLabels.y,
          legend: true,
        }),
      });
    }

    function createHorizontalBarChart(canvasId, rows, datasetLabel) {
      const options = sharedOptions({
        title: datasetLabel,
        xTitle: "Requests",
        yTitle: "Endpoint",
        legend: true,
      });

      options.indexAxis = "y";
      options.scales.x.ticks.precision = 0;

      return new Chart(document.getElementById(canvasId), {
        type: "bar",
        data: {
          labels: labels(rows),
          datasets: [
            {
              label: datasetLabel,
              data: values(rows),
              backgroundColor: chartColors(rows),
              borderRadius: 8,
            },
          ],
        },
        options,
      });
    }

    function createLineChart(canvasId, rows, datasetLabel, axisLabels = {}) {
      return new Chart(document.getElementById(canvasId), {
        type: "line",
        data: {
          labels: labels(rows),
          datasets: [
            {
              label: datasetLabel,
              data: values(rows),
              borderColor: "#174ea6",
              backgroundColor: "rgba(23, 78, 166, 0.14)",
              pointBackgroundColor: "#174ea6",
              pointBorderColor: "#ffffff",
              pointRadius: 5,
              pointHoverRadius: 8,
              fill: true,
              tension: 0.32,
            },
          ],
        },
        options: sharedOptions({
          title: datasetLabel,
          xTitle: axisLabels.x,
          yTitle: axisLabels.y,
          legend: true,
        }),
      });
    }

    function createPieLikeChart(canvasId, type, rows, datasetLabel) {
      return new Chart(document.getElementById(canvasId), {
        type,
        data: {
          labels: labels(rows),
          datasets: [
            {
              label: datasetLabel,
              data: values(rows),
              backgroundColor: chartColors(rows),
              borderColor: "#ffffff",
              borderWidth: 2,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: true,
              position: "bottom",
              labels: {
                boxWidth: 14,
                usePointStyle: true,
              },
            },
            tooltip: {
              enabled: true,
            },
            title: {
              display: true,
              text: datasetLabel,
            },
          },
        },
      });
    }

    function createRadarChart(canvasId, rows) {
      return new Chart(document.getElementById(canvasId), {
        type: "radar",
        data: {
          labels: labels(rows),
          datasets: [
            {
              label: "Completeness %",
              data: values(rows),
              borderColor: "#7c3aed",
              backgroundColor: "rgba(124, 58, 237, 0.2)",
              pointBackgroundColor: "#7c3aed",
              pointBorderColor: "#ffffff",
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: true,
              position: "bottom",
            },
            tooltip: {
              enabled: true,
              callbacks: {
                label(context) {
                  return `${context.dataset.label}: ${context.parsed.r}%`;
                },
              },
            },
            title: {
              display: true,
              text: "Profile section completion",
            },
          },
          scales: {
            r: {
              min: 0,
              max: 100,
              ticks: {
                stepSize: 20,
                callback(value) {
                  return `${value}%`;
                },
              },
              pointLabels: {
                font: {
                  size: 12,
                },
              },
            },
          },
        },
      });
    }

    const tokenRows = normalizeRows(graphData.byTokenStatus, "No tokens");
    const outcomeRows = normalizeRows(graphData.byApiOutcome, "No requests");
    const healthRows = [...outcomeRows, ...tokenRows.map((row) => ({
      label: `Token ${row.label}`,
      value: row.value,
    }))];

    createBarChart("programmeChart", graphData.byProgramme, "Records by programme", {
      x: "Programme",
      y: "Records",
    });
    createLineChart("graduationChart", graphData.byGraduationYear, "Graduation year trend", {
      x: "Graduation year",
      y: "Records",
    });
    createPieLikeChart("industryChart", "pie", graphData.byIndustrySector, "Industry sector split");
    createPieLikeChart("bidChart", "doughnut", graphData.byBidStatus, "Blind bidding status");
    createHorizontalBarChart("endpointChart", graphData.byApiEndpoint, "Endpoint usage");
    createLineChart("apiDailyChart", graphData.byApiDailyUsage, "API requests by day", {
      x: "Date",
      y: "Requests",
    });
    createRadarChart("completenessChart", graphData.profileCompletenessRadar);
    createPieLikeChart("apiHealthChart", "polarArea", healthRows, "API outcomes and token status");
  </script>
</body>
</html>
