# Express server
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_secret
SESSION_MAX_AGE_MINUTES=60
NODE_ENV=development

# Registration and password security
ALLOWED_EMAIL_DOMAINS=iit.ac.lk,westminster.ac.uk
DEVELOPER_EMAILS=developer@iit.ac.lk,developer@westminster.ac.uk
BCRYPT_SALT_ROUNDS=12
VERIFICATION_TOKEN_TTL_MINUTES=1440
API_TOKEN_TTL_DAYS=30

# App URLs
APP_BASE_URL=http://localhost:3000

# SMTP / email delivery
MAIL_SERVICE=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_sender_gmail@gmail.com
MAIL_PASS=your_16_character_app_password
MAIL_FROM=your_sender_gmail@gmail.com

# Browser-based API access control
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Verified university alumni events
ALUMNI_EVENT_CATALOG=University Alumni Networking Evening|2026-03-20|EASTMINSTER-ALUMNI-2026

# Blind bidding background recovery
BLIND_BID_RECOVERY_INTERVAL_MINUTES=5
