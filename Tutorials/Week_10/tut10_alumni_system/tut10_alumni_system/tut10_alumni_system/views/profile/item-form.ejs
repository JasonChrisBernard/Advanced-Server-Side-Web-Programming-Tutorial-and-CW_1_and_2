<%- include('../partials/header') %>
<section class="card">
  <h1><%= title %></h1>
  <form method="POST" action="<%= action %>" class="form-grid">
    <label>Type
      <select name="item_type" required>
        <% allowedTypes.forEach(function(type) { %>
          <option value="<%= type %>" <%= item.item_type === type ? 'selected' : '' %>><%= type %></option>
        <% }) %>
      </select>
    </label>
    <label>Title
      <input name="title" value="<%= item.title || '' %>" required placeholder="BSc Software Engineering / AWS Certificate">
    </label>
    <label>Institution
      <input name="institution" value="<%= item.institution || '' %>" placeholder="University / Provider">
    </label>
    <label>Field of Study / Skill Area
      <input name="field_of_study" value="<%= item.field_of_study || '' %>" placeholder="Computer Science / Cloud / Data Science">
    </label>
    <label>Start Date
      <input type="date" name="start_date" value="<%= item.start_date || '' %>">
    </label>
    <label>End Date
      <input type="date" name="end_date" value="<%= item.end_date || '' %>">
    </label>
    <label class="full">Description
      <textarea name="description" rows="4"><%= item.description || '' %></textarea>
    </label>
    <button class="btn primary full" type="submit">Save</button>
  </form>
</section>
<%- include('../partials/footer') %>
