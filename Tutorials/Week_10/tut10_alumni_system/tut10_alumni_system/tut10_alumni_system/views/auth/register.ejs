<%- include('../partials/header') %>
<section class="card auth-card">
  <h1>Alumni Registration</h1>
  <p class="muted">Create an alumni profile using your university email address.</p>

  <% if (errors && errors.length) { %>
    <div class="alert error">
      <% errors.forEach(function(error) { %>
        <p><%= error.msg %></p>
      <% }) %>
    </div>
  <% } %>

  <form method="POST" action="/auth/register" class="form-grid">
    <label>First Name
      <input name="first_name" value="<%= formData.first_name || '' %>" required>
    </label>
    <label>Last Name
      <input name="last_name" value="<%= formData.last_name || '' %>" required>
    </label>
    <label>Email
      <input type="email" name="email" value="<%= formData.email || '' %>" required placeholder="student@westminster.ac.uk">
    </label>
    <label>Program
      <input name="program" value="<%= formData.program || '' %>" placeholder="Software Engineering">
    </label>
    <label>Graduation Year
      <input type="number" name="graduation_year" value="<%= formData.graduation_year || '' %>" min="1950" max="2100">
    </label>
    <label>Industry Sector
      <input name="industry_sector" value="<%= formData.industry_sector || '' %>" placeholder="Technology">
    </label>
    <label>Current Job Title
      <input name="current_job_title" value="<%= formData.current_job_title || '' %>" placeholder="Software Engineer">
    </label>
    <label>Company
      <input name="company" value="<%= formData.company || '' %>" placeholder="Company name">
    </label>
    <label class="full">LinkedIn URL
      <input type="url" name="linkedin_url" value="<%= formData.linkedin_url || '' %>" placeholder="https://www.linkedin.com/in/username">
    </label>
    <label>Password
      <input type="password" name="password" required minlength="8">
    </label>
    <label>Confirm Password
      <input type="password" name="confirm_password" required minlength="8">
    </label>
    <button class="btn primary full" type="submit">Create Account</button>
  </form>
</section>
<%- include('../partials/footer') %>
