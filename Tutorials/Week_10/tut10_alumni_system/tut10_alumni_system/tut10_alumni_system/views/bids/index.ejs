<%- include('../partials/header') %>
<section class="hero-grid">
  <div class="card">
    <h1>Blind Bidding System</h1>
    <p class="muted">Place a private bid to be selected as Alumni of the Day. The current highest bid is hidden.</p>
    <div class="stats-row">
      <div class="stat"><span><%= summary.monthlyCount %>/3</span><small>Monthly bid days used</small></div>
      <div class="stat"><span><%= summary.remainingMonthlyBids %></span><small>Remaining this month</small></div>
      <div class="stat"><span><%= summary.todayBid ? 'Yes' : 'No' %></span><small>Bid placed today</small></div>
    </div>
    <form method="POST" action="/bids/place" class="stack-form">
      <% if (currentUser && currentUser.role === 'alumni') { %>
  <form method="POST" action="/bids/place" class="stack-form">
    <label><%= summary.todayBid ? 'Increase Today’s Bid' : 'Place Today’s Bid' %>
      <input type="number" name="bid_amount" min="1" step="0.01" required placeholder="Enter private amount">
    </label>
    <button class="btn primary" type="submit"><%= summary.todayBid ? 'Increase Blind Bid' : 'Place Blind Bid' %></button>
  </form>
<% } else { %>
  <p class="muted">Developer accounts can monitor bidding, but cannot place alumni bids.</p>
<% } %>

  <div class="card featured-card">
    <h2>Alumni of the Day</h2>
    <% if (summary.todayWinner) { %>
      <% if (summary.todayWinner.profile_image) { %>
        <img class="avatar large" src="/uploads/<%= summary.todayWinner.profile_image %>" alt="Winner image">
      <% } %>
      <h3><%= summary.todayWinner.first_name %> <%= summary.todayWinner.last_name %></h3>
      <p><%= summary.todayWinner.current_job_title || 'Professional profile' %> <%= summary.todayWinner.company ? 'at ' + summary.todayWinner.company : '' %></p>
      <p class="muted"><%= summary.todayWinner.program || '' %></p>
    <% } else { %>
      <p class="muted">No winner has been selected for today yet. The scheduled job runs at midnight.</p>
    <% } %>
    <% if (currentUser && currentUser.role === 'developer') { %>
      <form method="POST" action="/bids/run-selection" onsubmit="return confirm('Run winner selection manually for demo?')">
        <button class="btn secondary" type="submit">Run Midnight Selection Demo</button>
      </form>
    <% } %>
  </div>
</section>

<section class="card">
  <h2>My Bid History</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Amount</th>
          <th>Status</th>
          <th>Featured Date</th>
        </tr>
      </thead>
      <tbody>
        <% if (summary.history.length) { %>
          <% summary.history.forEach(function(bid) { %>
            <tr>
              <td><%= bid.bid_date %></td>
              <td>£<%= Number(bid.bid_amount).toFixed(2) %></td>
              <td><span class="badge"><%= bid.status %></span></td>
              <td><%= bid.feature_date || '-' %></td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="4">No bids placed yet.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
<%- include('../partials/footer') %>
