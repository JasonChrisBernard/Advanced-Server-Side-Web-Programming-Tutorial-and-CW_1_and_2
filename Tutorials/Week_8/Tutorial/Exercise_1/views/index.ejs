<!DOCTYPE html>
<html>
<head>
  <title>OMDb Movie Search</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <div class="container">
    <h1>OMDb Movie Search</h1>

    <form id="movieSearchForm">
      <input 
        type="text" 
        id="movieInput" 
        placeholder="Enter a movie title"
        required
      >

      <button type="submit">Search</button>
    </form>

    <p id="message"></p>

    <div id="movieResults" class="movie-grid"></div>
  </div>

  <script src="/js/movieSearch.js"></script>
</body>
</html>